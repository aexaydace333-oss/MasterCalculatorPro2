<?xml version="1.0" encoding="utf-8"?>

<manifest xmlns:android="http://schemas.android.com/apk/res/android">


    <!-- Internet permission for future AI/text solving and updates -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- PDF export and file handling -->
    <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />

    <!-- Android 13+ notifications -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Calculator button vibration feedback -->
    <uses-permission android:name="android.permission.VIBRATE" />


    <application

        android:allowBackup="true"

        android:label="Master Calculator Pro"

        android:supportsRtl="true"

        android:theme="@style/Theme.MasterCalculatorPro">


        <!-- Main App Screen -->

        <activity

            android:name=".MainActivity"

            android:exported="true">


            <intent-filter>

                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />

            </intent-filter>


        </activity>


        <!-- Scientific Calculator Module -->

        <activity

            android:name=".ScientificCalculatorActivity"

            android:exported="false" />


        <!-- Geometry Calculator -->

        <activity

            android:name=".GeometryActivity"

            android:exported="false" />


        <!-- Statistics Module -->

        <activity

            android:name=".StatisticsActivity"

            android:exported="false" />


        <!-- Financial Calculator -->

        <activity

            android:name=".FinancialCalculatorActivity"

            android:exported="false" />


        <!-- Games Section -->

        <activity

            android:name=".GamesActivity"

            android:exported="false" />


        <!-- AI/Text Question Solver -->

        <activity

            android:name=".QuestionSolverActivity"

            android:exported="false" />


    </application>


</manifest>
