<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Internet access for future AI/text calculation features -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Export calculations, reports and PDF files -->
    <uses-permission android:name="android.permission.READ_MEDIA_IMAGES" />
    <uses-permission android:name="android.permission.READ_MEDIA_DOCUMENTS" />

    <!-- Notifications (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Keep app running for calculation history/background tasks -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Optional vibration feedback for calculator keys -->
    <uses-permission android:name="android.permission.VIBRATE" />


    <application

        android:name=".MasterCalculatorApplication"

        android:allowBackup="true"

        android:dataExtractionRules="@xml/data_extraction_rules"

        android:fullBackupContent="@xml/backup_rules"

        android:icon="@mipmap/ic_launcher"

        android:label="Master Calculator Pro"

        android:roundIcon="@mipmap/ic_launcher_round"

        android:supportsRtl="true"

        android:theme="@style/Theme.MasterCalculatorPro">


        <!-- Main Calculator Activity -->
        <activity

            android:name=".MainActivity"

            android:exported="true"

            android:screenOrientation="portrait">


            <intent-filter>

                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />

            </intent-filter>

        </activity>


        <!-- Scientific Calculator -->
        <activity
            android:name=".calculator.ScientificCalculatorActivity"
            android:exported="false" />


        <!-- Statistics Module -->
        <activity
            android:name=".statistics.StatisticsActivity"
            android:exported="false" />


        <!-- ANOVA -->
        <activity
            android:name=".statistics.AnovaActivity"
            android:exported="false" />


        <!-- T Test -->
        <activity
            android:name=".statistics.TTestActivity"
            android:exported="false" />


        <!-- Chi Square -->
        <activity
            android:name=".statistics.ChiSquareActivity"
            android:exported="false" />


        <!-- Mann Whitney -->
        <activity
            android:name=".statistics.MannWhitneyActivity"
            android:exported="false" />


        <!-- Kruskal Wallis -->
        <activity
            android:name=".statistics.KruskalWallisActivity"
            android:exported="false" />


        <!-- Geometry Calculator -->
        <activity
            android:name=".geometry.GeometryActivity"
            android:exported="false" />


        <!-- Financial Calculator -->
        <activity
            android:name=".finance.FinancialCalculatorActivity"
            android:exported="false" />


        <!-- Games Section -->
        <activity
            android:name=".games.GamesActivity"
            android:exported="false" />


        <!-- PDF Export Viewer -->
        <activity
            android:name=".export.PdfViewerActivity"
            android:exported="false" />


        <!-- AI/Text Question Calculator -->
        <activity
            android:name=".ai.QuestionSolverActivity"
            android:exported="false" />


        <!-- Share exported calculations -->
        <provider

            android:name="androidx.core.content.FileProvider"

            android:authorities="${applicationId}.fileprovider"

            android:exported="false"

            android:grantUriPermissions="true">


            <meta-data

                android:name="android.support.FILE_PROVIDER_PATHS"

                android:resource="@xml/file_paths" />

        </provider>


    </application>

</manifest>
